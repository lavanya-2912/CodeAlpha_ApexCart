PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/apexcart
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# Cloudinary Config (Optional: falls back to local upload system if left blank)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe Config (Optional: falls back to manual COD and mock payments if left blank)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Mail Server Config (Optional: falls back to console logging if left blank)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@apexcart.com
